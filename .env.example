# ─── Backend (backend/.env) ───────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key              # Used only for JWT verification
SUPABASE_SERVICE_KEY=your_supabase_service_role_key  # Used for all DB reads/writes (bypasses RLS)
GITHUB_TOKEN=optional_github_personal_access_token   # Raises rate limit from 60 to 5000 req/hr

# ─── Internal Database (optional) ─────────────────────────────────────────────
# Set DATABASE=internal_db to use local PostgreSQL instead of Supabase for data storage.
# Auth (JWT verification) always goes through Supabase regardless of this setting.
DATABASE=supabase                                    # Options: supabase | internal_db
INTERNAL_DB_URL=postgresql://repos_user:change_me_in_production@localhost:5432/repos_db

# ─── Frontend (frontend/.env) ─────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
